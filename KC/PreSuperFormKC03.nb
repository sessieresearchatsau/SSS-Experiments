      RowBox[{
       RowBox[{"Numeric", "[", "list_List", "]"}], ",", "form_"}], "]"}], ":=",
      "\[IndentingNewLine]", "  ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"str", "=", 
         RowBox[{"StringJoin", "[", 
          RowBox[{"ToString", " ", "/@", " ", "list"}], "]"}]}], "}"}], ",", 
       "\[IndentingNewLine]", "    ", 
       RowBox[{"InterpretationBox", "[", 
        RowBox[{"str", ",", 
         RowBox[{"Numeric", "[", "list", "]"}]}], "]"}]}], 
      "\[IndentingNewLine]", "  ", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Create", " ", "an", " ", "addition", " ", "operation", " ", "for", " ", 
     "Numeric", " ", "objects"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Numeric", " ", "/:", " ", 
     RowBox[{"Plus", "[", 
      RowBox[{"n1_Numeric", ",", "n2_Numeric"}], "]"}], ":=", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"Numeric", "[", 
      RowBox[{"IntegerDigits", "[", 
       RowBox[{
        RowBox[{"FromDigits", "[", 
         RowBox[{"n1", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}], "+", 
        RowBox[{"FromDigits", "[", 
         RowBox[{"n2", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Create", " ", "a", " ", "multiplication", " ", "operation", " ", "for", " ",
      "Numeric", " ", "objects"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Numeric", " ", "/:", " ", 
     RowBox[{"Times", "[", 
      RowBox[{"n_Numeric", ",", "k_Integer"}], "]"}], ":=", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"Numeric", "[", 
      RowBox[{"IntegerDigits", "[", 
       RowBox[{
        RowBox[{"FromDigits", "[", 
         RowBox[{"n", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}], "*", "k"}], "]"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Example", " ", "usage"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n1", "=", 
