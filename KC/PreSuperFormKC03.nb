Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ReduceNumeric", "[", "i_Integer", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"iDigits", "=", 
        RowBox[{"IntegerDigits", "[", "i", "]"}]}], ",", "reducedI", ",", 
       RowBox[{"iD0", "=", 
        RowBox[{"{", "}"}]}], ",", "repLen"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"repLen", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"iDigits", "!=", "iD0"}], ",", " ", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "guaranteed", " ", "to", " ", "run", " ", "at", " ", "least", " ", 
           "once"}], ",", " ", 
          RowBox[{"given", " ", "init", " ", "values"}]}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "iDigits", "]"}], "==", "1"}], ",", 
           RowBox[{"Return", "[", 
            RowBox[{"First", "@", "iDigits"}], "]"}]}], "]"}], ";", " ", 
         RowBox[{"(*", " ", 
          RowBox[{"nothing", " ", "more", " ", "to", " ", "do"}], " ", "*)"}],
          "\[IndentingNewLine]", 
         RowBox[{"iD0", "=", "iDigits"}], ";", " ", 
         RowBox[{"(*", " ", 
          RowBox[{"note", " ", "the", " ", "previous", " ", "list"}], " ", 
          "*)"}], "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
          "first", " ", "compress", " ", "subsequences", " ", "of", " ", 
           "duplicate", " ", "elements"}], " ", "*)"}], "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"repLen", "==", "1"}], ",", "\[IndentingNewLine]", 
           RowBox[{"iDigits", "=", 
            RowBox[{"Map", "[", "\[IndentingNewLine]", "    ", 
             RowBox[{
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Length", "[", "#", "]"}], ">", "1"}], ",", 
                 "\[IndentingNewLine]", "      ", 
                 RowBox[{"IndexedConcatenate", "[", 
                  RowBox[{
                   RowBox[{"First", "[", "#", "]"}], ",", 
                   RowBox[{"Length", "[", "#", "]"}]}], "]"}], ",", 
                 RowBox[{"(*", " ", 
                  RowBox[{
                  "Use", " ", "IndexedConcatenate", " ", "for", " ", "groups",
                    " ", "longer", " ", "than", " ", "1"}], " ", "*)"}], 
                 "\[IndentingNewLine]", "      ", 
                 RowBox[{"First", "[", "#", "]"}]}], "\[IndentingNewLine]", 
                "    ", "]"}], " ", "&"}], ",", "\[IndentingNewLine]", "    ", 
              RowBox[{"SplitBy", "[", 
               RowBox[{"iDigits", ",", "Identity"}], "]"}]}], " ", 
             RowBox[{"(*", " ", 
              RowBox[{
              "Group", " ", "consecutive", " ", "identical", " ", 
               "elements"}], " ", "*)"}], "\[IndentingNewLine]", "]"}]}]}], 
          "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{"$debug", ",", 
           RowBox[{"Print", "[", 
            
            RowBox[{"\"\<repLen=\>\"", ",", "repLen", ",", "\"\<: \>\"", ",", 
             "iDigits"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "iDigits", "]"}], "<=", "1"}], ",", 
           RowBox[{"Return", "[", 
            RowBox[{"First", "@", "iDigits"}], "]"}]}], "]"}], ";", " ", 
         RowBox[{"(*", " ", 
          RowBox[{"nothing", " ", "more", " ", "to", " ", "do"}], " ", "*)"}],
          "\[IndentingNewLine]", 
         RowBox[{"repLen", "++"}], ";", "  ", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{
           "now", " ", "start", " ", "with", " ", "repeating", " ", "unit", " ",
             "length", " ", "2"}], ",", " ", 
           RowBox[{"up", " ", "to", " ", "max", " ", "useful"}]}], " ", 
          "*)"}], "\[IndentingNewLine]", 
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"repLen", ">", "1"}], " ", "&&", " ", 
            RowBox[{
             RowBox[{"2", " ", "repLen"}], " ", "<=", " ", 
             RowBox[{"Length", "[", "iDigits", "]"}]}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"iDigits", "=", 
             RowBox[{"SequenceReplace", "[", 
              RowBox[{"iDigits", ",", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"x", ":", 
                  RowBox[{"Repeated", "[", 
                   RowBox[{
                    RowBox[{"PatternSequence", "@@", 
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{"ToExpression", "[", 
                    RowBox[{
                    RowBox[{"ToString", "@", 
                    RowBox[{"Unique", "[", "x", "]"}]}], "<>", "\"\<_\>\""}], 
                    "]"}], ",", 
                    RowBox[{"{", "repLen", "}"}]}], "]"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"2", ",", "\[Infinity]"}], "}"}]}], "]"}]}], 
                 "}"}], ":>", 
                RowBox[{"IndexedConcatenate", "[", 
                 RowBox[{
                  RowBox[{"Concatenate", " ", "@@", " ", 
                   RowBox[{"(", 
                    RowBox[{"SequenceReplace", "[", 
                    RowBox[{
                    RowBox[{"Take", "[", 
                    RowBox[{
                    RowBox[{"{", "x", "}"}], ",", "repLen"}], "]"}], ",", 
                    RowBox[{
                    RowBox[{"{", "a__Integer", "}"}], " ", ":>", 
                    RowBox[{"IntegerString", "[", 
                    RowBox[{
                    RowBox[{"FromDigits", "[", 
                    RowBox[{"{", "a", "}"}], "]"}], ",", "10", ",", 
                    "repLen"}], "]"}]}]}], "]"}], ")"}]}], ",", 
                  RowBox[{
                   RowBox[{"Length", "[", 
                    RowBox[{"{", "x", "}"}], "]"}], "/", "repLen"}]}], 
                 "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"iDigits", "==", "iD0"}], ",", 
              RowBox[{"repLen", "++"}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{"$debug", ",", 
                 RowBox[{"Print", "[", 
                  
                  RowBox[{"\"\<repLen=\>\"", ",", "repLen", ",", "\"\<: \>\"",
                    ",", "iDigits"}], "]"}]}], "]"}], ";", 
               RowBox[{"repLen", "=", "1"}]}]}], "\[IndentingNewLine]", 
             "]"}]}]}], " ", 
          RowBox[{"(*", " ", 
           RowBox[{
           "flag", " ", "to", " ", "restart", " ", "exit", " ", "inner", " ", 
            "loop", " ", "and", " ", "restart", " ", "outer", " ", "While", " ",
             "loop"}], " ", "*)"}], "\[IndentingNewLine]", "]"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", " ", 
      RowBox[{"Concatenate", " ", "@@", " ", 
       RowBox[{"(", 
        RowBox[{"SequenceReplace", "[", 
         RowBox[{"iDigits", ",", 
          RowBox[{
           RowBox[{"{", "a__Integer", "}"}], " ", ":>", 
           RowBox[{"IntegerString", "[", 
            RowBox[{
             RowBox[{"FromDigits", "[", 
              RowBox[{"{", "a", "}"}], "]"}], ",", "10", ",", 
             RowBox[{"Length", "[", 
              RowBox[{"{", "a", "}"}], "]"}]}], "]"}]}]}], "]"}], ")"}]}]}]}],
     "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981033137936264*^9, 3.9810331907421722`*^9}, {
   3.9810332746365166`*^9, 3.981033281695242*^9}, {3.981033325549721*^9, 
