Cell["\<\
This first version of ReduceNumeric doesn\[CloseCurlyQuote]t correctly hand \
initial 0s, whether inside an I-Cat or outside.\
\>", "Text",
 CellChangeTimes->{{3.9811340215641823`*^9, 
  3.981134110423937*^9}},ExpressionUUID->"82cf1abd-683c-284a-a948-\
066db5e094dd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ReduceNumeric", "[", "i_Integer", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"iDigits", "=", 
        RowBox[{"IntegerDigits", "[", "i", "]"}]}], ",", "reducedI", ",", 
       RowBox[{"iD0", "=", 
        RowBox[{"{", "}"}]}], ",", "repLen"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"repLen", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"While", "[", 
       RowBox[{
        RowBox[{"iDigits", "!=", "iD0"}], ",", " ", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "guaranteed", " ", "to", " ", "run", " ", "at", " ", "least", " ", 
           "once"}], ",", " ", 
          RowBox[{"given", " ", "init", " ", "values"}]}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "iDigits", "]"}], "==", "1"}], ",", 
           RowBox[{"Return", "[", 
            RowBox[{"First", "@", "iDigits"}], "]"}]}], "]"}], ";", " ", 
         RowBox[{"(*", " ", 
          RowBox[{"nothing", " ", "more", " ", "to", " ", "do"}], " ", "*)"}],
          "\[IndentingNewLine]", 
         RowBox[{"iD0", "=", "iDigits"}], ";", " ", 
         RowBox[{"(*", " ", 
          RowBox[{"note", " ", "the", " ", "previous", " ", "list"}], " ", 
          "*)"}], "\[IndentingNewLine]", 
         RowBox[{"(*", " ", 
          RowBox[{
          "first", " ", "compress", " ", "subsequences", " ", "of", " ", 
           "duplicate", " ", "elements"}], " ", "*)"}], "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"repLen", "==", "1"}], ",", "\[IndentingNewLine]", 
           RowBox[{"iDigits", "=", 
            RowBox[{"Map", "[", "\[IndentingNewLine]", "    ", 
             RowBox[{
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Length", "[", "#", "]"}], ">", "1"}], ",", 
                 "\[IndentingNewLine]", "      ", 
                 RowBox[{"IndexedConcatenate", "[", 
                  RowBox[{
                   RowBox[{"First", "[", "#", "]"}], ",", 
                   RowBox[{"Length", "[", "#", "]"}]}], "]"}], ",", 
                 RowBox[{"(*", " ", 
                  RowBox[{
                  "Use", " ", "IndexedConcatenate", " ", "for", " ", "groups",
                    " ", "longer", " ", "than", " ", "1"}], " ", "*)"}], 
                 "\[IndentingNewLine]", "      ", 
                 RowBox[{"First", "[", "#", "]"}]}], "\[IndentingNewLine]", 
                "    ", "]"}], " ", "&"}], ",", "\[IndentingNewLine]", "    ", 
              RowBox[{"SplitBy", "[", 
               RowBox[{"iDigits", ",", "Identity"}], "]"}]}], " ", 
             RowBox[{"(*", " ", 
              RowBox[{
              "Group", " ", "consecutive", " ", "identical", " ", 
               "elements"}], " ", "*)"}], "\[IndentingNewLine]", "]"}]}]}], 
          "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{"$debug", ",", 
           RowBox[{"Print", "[", 
            
            RowBox[{"\"\<repLen=\>\"", ",", "repLen", ",", "\"\<: \>\"", ",", 
             "iDigits"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "iDigits", "]"}], "<=", "1"}], ",", 
           RowBox[{"Return", "[", 
            RowBox[{"First", "@", "iDigits"}], "]"}]}], "]"}], ";", " ", 
         RowBox[{"(*", " ", 
          RowBox[{"nothing", " ", "more", " ", "to", " ", "do"}], " ", "*)"}],
          "\[IndentingNewLine]", 
         RowBox[{"repLen", "++"}], ";", "  ", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{
           "now", " ", "start", " ", "with", " ", "repeating", " ", "unit", " ",
             "length", " ", "2"}], ",", " ", 
           RowBox[{"up", " ", "to", " ", "max", " ", "useful"}]}], " ", 
          "*)"}], "\[IndentingNewLine]", 
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"repLen", ">", "1"}], " ", "&&", " ", 
            RowBox[{
             RowBox[{"2", " ", "repLen"}], " ", "<=", " ", 
             RowBox[{"Length", "[", "iDigits", "]"}]}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"iDigits", "=", 
             RowBox[{"SequenceReplace", "[", 
              RowBox[{"iDigits", ",", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"x", ":", 
                  RowBox[{"Repeated", "[", 
                   RowBox[{
                    RowBox[{"PatternSequence", "@@", 
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{"ToExpression", "[", 
                    RowBox[{
                    RowBox[{"ToString", "@", 
                    RowBox[{"Unique", "[", "x", "]"}]}], "<>", "\"\<_\>\""}], 
                    "]"}], ",", 
                    RowBox[{"{", "repLen", "}"}]}], "]"}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"2", ",", "\[Infinity]"}], "}"}]}], "]"}]}], 
                 "}"}], ":>", 
                RowBox[{"IndexedConcatenate", "[", 
                 RowBox[{
                  RowBox[{"Concatenate", " ", "@@", " ", 
                   RowBox[{"(", 
                    RowBox[{"SequenceReplace", "[", 
                    RowBox[{
                    RowBox[{"Take", "[", 
                    RowBox[{
                    RowBox[{"{", "x", "}"}], ",", "repLen"}], "]"}], ",", 
                    RowBox[{
                    RowBox[{"{", "a__Integer", "}"}], " ", ":>", 
                    RowBox[{"FromDigits", "[", 
                    RowBox[{"{", "a", "}"}], "]"}]}]}], "]"}], ")"}]}], ",", 
                  RowBox[{
                   RowBox[{"Length", "[", 
                    RowBox[{"{", "x", "}"}], "]"}], "/", "repLen"}]}], 
                 "]"}]}]}], "\[IndentingNewLine]", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"iDigits", "==", "iD0"}], ",", 
              RowBox[{"repLen", "++"}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{"$debug", ",", 
                 RowBox[{"Print", "[", 
                  
                  RowBox[{"\"\<repLen=\>\"", ",", "repLen", ",", "\"\<: \>\"",
                    ",", "iDigits"}], "]"}]}], "]"}], ";", 
               RowBox[{"repLen", "=", "1"}]}]}], "\[IndentingNewLine]", 
             "]"}]}]}], " ", 
          RowBox[{"(*", " ", 
           RowBox[{
           "flag", " ", "to", " ", "restart", " ", "exit", " ", "inner", " ", 
            "loop", " ", "and", " ", "restart", " ", "outer", " ", "While", " ",
             "loop"}], " ", "*)"}], "\[IndentingNewLine]", "]"}]}]}], 
       "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", " ", 
      RowBox[{"Concatenate", " ", "@@", " ", 
       RowBox[{"(", 
        RowBox[{"SequenceReplace", "[", 
         RowBox[{"iDigits", ",", 
          RowBox[{
           RowBox[{"{", "a__Integer", "}"}], " ", ":>", 
           RowBox[{"FromDigits", "[", 
            RowBox[{"{", "a", "}"}], "]"}]}]}], "]"}], ")"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.981033137936264*^9, 3.9810331907421722`*^9}, {
   3.9810332746365166`*^9, 3.981033281695242*^9}, {3.981033325549721*^9, 
   3.9810333476826286`*^9}, {3.981033393118284*^9, 3.9810333931923523`*^9}, {
   3.981033513026169*^9, 3.9810335566531677`*^9}, {3.9810336044003296`*^9, 
