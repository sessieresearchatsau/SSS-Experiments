Cell["\<\
Format[IndexedConcatenate[x__, finish_]] := Module[{bra, ket},
   Which[
    Length[{x}] > 1, {bra, ket} = {\"[\", \"]\"},
    (* Head[x]==Integer &  0<x<9,{\"\",\"\"}, *)
    Head[x] === Integer, {bra, ket} = {\"(\", \")\"},
    Length[{x}] <= 1, bra = ket = Nothing
    ];
   DisplayForm[RowBox[{OverscriptBox[\"\[Euro]\", finish], bra, Sequence @@ \
Riffle[{x}, \",\"], ket}]]
   ];\
\>", "Text",
 InitializationCell->True,
