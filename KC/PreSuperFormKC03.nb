Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "Numeric", " ", "object", " ", "as", " ", "a", " ",
     "wrapper", " ", "for", " ", "a", " ", "list", " ", "of", " ", 
    "integers"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "Numeric", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Numeric", " ", "/:", " ", 
     RowBox[{"MakeBoxes", "[", 
      RowBox[{
       RowBox[{"Numeric", "[", "list_List", "]"}], ",", "form_"}], "]"}], ":=",
      "\[IndentingNewLine]", "  ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"str", "=", 
         RowBox[{"StringJoin", "[", 
          RowBox[{"ToString", " ", "/@", " ", "list"}], "]"}]}], "}"}], ",", 
       "\[IndentingNewLine]", "    ", 
       RowBox[{"InterpretationBox", "[", 
        RowBox[{"str", ",", 
         RowBox[{"Numeric", "[", "list", "]"}]}], "]"}]}], 
      "\[IndentingNewLine]", "  ", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Create", " ", "an", " ", "addition", " ", "operation", " ", "for", " ", 
     "Numeric", " ", "objects"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Numeric", " ", "/:", " ", 
     RowBox[{"Plus", "[", 
      RowBox[{"n1_Numeric", ",", "n2_Numeric"}], "]"}], ":=", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"maxLength", ",", "sum"}], "}"}], ",", "\[IndentingNewLine]", 
       "    ", 
       RowBox[{
        RowBox[{"maxLength", "=", 
         RowBox[{"Max", "[", 
          RowBox[{
           RowBox[{"Length", "[", 
            RowBox[{"n1", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
           RowBox[{"Length", "[", 
            RowBox[{"n2", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"sum", "=", 
         RowBox[{"IntegerDigits", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"FromDigits", "[", 
             RowBox[{"n1", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}], "+", 
            RowBox[{"FromDigits", "[", 
             RowBox[{"n2", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ",", "10", ",", 
           "maxLength"}], "]"}]}], ";", "\[IndentingNewLine]", "    ", 
        RowBox[{"Numeric", "[", "sum", "]"}]}]}], "\[IndentingNewLine]", "  ",
       "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Create", " ", "a", " ", "multiplication", " ", "operation", " ", "for", " ",
      "Numeric", " ", "objects"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Numeric", " ", "/:", " ", 
     RowBox[{"Times", "[", 
      RowBox[{"n_Numeric", ",", "k_Integer"}], "]"}], ":=", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"length", ",", "product"}], "}"}], ",", "\[IndentingNewLine]",
        "    ", 
       RowBox[{
        RowBox[{"length", "=", 
         RowBox[{"Length", "[", 
          RowBox[{"n", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"product", "=", 
         RowBox[{"IntegerDigits", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"FromDigits", "[", 
             RowBox[{"n", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}], "*", "k"}], ",", "10", ",",
            "length"}], "]"}]}], ";", "\[IndentingNewLine]", "    ", 
        RowBox[{"Numeric", "[", "product", "]"}]}]}], "\[IndentingNewLine]", 
      "  ", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Example", " ", "usage"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n1", "=", 
     RowBox[{"Numeric", "[", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1", ",", "2", ",", "3"}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n2", "=", 
     RowBox[{"Numeric", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "5", ",", "6"}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Display", " ", "the", " ", "Numeric", " ", "objects"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"n1", ",", "n2"}], "}"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Add", " ", "and", " ", "multiply", " ", "Numeric", " ", "objects"}], ",",
      " ", 
     RowBox[{"preserving", " ", "leading", " ", "zeros"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"n1", "+", "n2"}], "\[IndentingNewLine]", 
   RowBox[{"3", " ", "n1"}], "\[IndentingNewLine]", 
   RowBox[{"0", " ", "n2"}], "\[IndentingNewLine]", 
   RowBox[{"-", "n1"}], "\[IndentingNewLine]", 
   RowBox[{"n2", "-", "n1"}]}]}]], "Input",
