Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "Numeric", " ", "object", " ", "as", " ", "a", " ",
     "wrapper", " ", "for", " ", "a", " ", "list", " ", "of", " ", 
    "integers"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "Numeric", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Custom", " ", "display", " ", "for", " ", "Numeric", " ", "objects"}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Numeric", " ", "/:", " ", 
     RowBox[{"MakeBoxes", "[", 
      RowBox[{
       RowBox[{"Numeric", "[", "list_List", "]"}], ",", "form_"}], "]"}], ":=",
      "\[IndentingNewLine]", "  ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"str", "=", 
         RowBox[{"StringJoin", "[", 
          RowBox[{"ToString", " ", "/@", " ", "list"}], "]"}]}], "}"}], ",", 
       "\[IndentingNewLine]", "    ", 
       RowBox[{"InterpretationBox", "[", 
        RowBox[{"str", ",", 
         RowBox[{"Numeric", "[", "list", "]"}]}], "]"}]}], 
      "\[IndentingNewLine]", "  ", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Addition", " ", "operation", " ", "for", " ", "Numeric", " ", 
      "objects"}], ",", " ", 
     RowBox[{"extended", " ", "to", " ", "handle", " ", "subtraction"}]}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Numeric", " ", "/:", " ", 
     RowBox[{"Plus", "[", 
      RowBox[{"n1_Numeric", ",", "n2_Numeric"}], "]"}], ":=", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"maxLength", ",", "sum", ",", "result", ",", "sign"}], "}"}], 
       ",", "\[IndentingNewLine]", "    ", 
       RowBox[{
        RowBox[{"maxLength", "=", 
         RowBox[{"Max", "[", 
          RowBox[{
           RowBox[{"Length", "[", 
            RowBox[{"n1", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
           RowBox[{"Length", "[", 
            RowBox[{"n2", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"sum", "=", 
         RowBox[{
          RowBox[{"FromDigits", "[", 
           RowBox[{"n1", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "+", 
          RowBox[{"FromDigits", "[", 
           RowBox[{"n2", "[", 
