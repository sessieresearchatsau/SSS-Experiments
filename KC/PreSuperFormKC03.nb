   3.9810479138692055`*^9}, {3.9810479679234276`*^9, 3.981047987290943*^9}, {
   3.9810480927806053`*^9, 3.9810483988702393`*^9}, {3.981048436028179*^9, 
   3.981048494192749*^9}, {3.9810486093788776`*^9, 3.981048626678152*^9}, {
   3.9810507350213375`*^9, 3.981050805942768*^9}, {3.9810508526624126`*^9, 
   3.981050877057579*^9}, {3.981050920099083*^9, 3.981050927344261*^9}, {
   3.9810512344027576`*^9, 3.98105126953961*^9}, {3.981051312053152*^9, 
