Cell["The last test failed: n2-n1 gave an unexpected result.", "ChatInput",
 CellDingbat->Cell[
   BoxData[
    DynamicBox[
     ToBoxes[
      If[
       TrueQ[CloudSystem`$CloudNotebooks], 
       RawBoxes[
        TemplateBox[{}, "ChatIconUser"]], 
