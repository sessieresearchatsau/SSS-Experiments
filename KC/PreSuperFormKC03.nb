    "Add", " ", "and", " ", "multiply", " ", "Numeric", " ", "objects"}], " ",
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{"n1", "+", "n2"}], "\[IndentingNewLine]", 
   RowBox[{"n1", "*", "3"}]}]}]], "Input",
