Cell[BoxData[{
 RowBox[{"Clear", "[", "resolveCarryWithLog", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"resolveCarryWithLog", "[", 
   RowBox[{"l", ":", 
    RowBox[{"{", "__Integer", "}"}]}], "]"}], ":=", "\[IndentingNewLine]", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"carryList", "=", "l"}], ",", 
      RowBox[{"changes", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"pos", "=", 
       RowBox[{"Length", "[", "l", "]"}]}], ",", "x", ",", "y", ",", 
      RowBox[{"states", "=", 
       RowBox[{"{", "l", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"pos", ">", "1"}], ",", "\[IndentingNewLine]", "   ", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}], "=", 
         RowBox[{"carryList", "[", 
          RowBox[{"[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"pos", "-", "1"}], ",", "pos"}], "}"}], "]"}], "]"}]}], ";",
         "\[IndentingNewLine]", "   ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"y", "<", "0"}], "||", 
           RowBox[{"y", ">", "9"}]}], ",", "\[IndentingNewLine]", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{"carryList", "[", 
             RowBox[{"[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"pos", "-", "1"}], ",", "pos"}], "}"}], "]"}], "]"}], 
            "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"x", "+", 
               RowBox[{"Quotient", "[", 
                RowBox[{"y", ",", "10"}], "]"}]}], ",", 
              RowBox[{"Mod", "[", 
               RowBox[{"y", ",", "10"}], "]"}]}], "}"}]}], ";", 
           "\[IndentingNewLine]", "    ", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"states", ",", "carryList"}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "   ", "]"}], ";", "\[IndentingNewLine]", 
        "   ", 
        RowBox[{"pos", "--"}], ";"}]}], "\[IndentingNewLine]", "  ", "]"}], ";",
      "\[IndentingNewLine]", "  ", "states"}]}], "\[IndentingNewLine]", " ", 
   "]"}]}]}], "Input",
 InitializationCell->True,
 CellChangeTimes->{{3.981135385589512*^9, 3.981135410757765*^9}, {
  3.9811355350499134`*^9, 3.9811355374781265`*^9}, {3.981401283508911*^9, 
