  RowBox[{
   RowBox[{"resolveCarry", "[", 
    RowBox[{"l", ":", 
     RowBox[{"{", "__Integer", "}"}]}], "]"}], ":=", " ", 
   RowBox[{"ReplaceRepeated", "[", 
    RowBox[{"l", ",", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a___", ",", "x_", ",", 
        RowBox[{"y_", " ", "/;", " ", 
         RowBox[{"!", 
          RowBox[{"(", 
           RowBox[{"0", "<=", "y", "<=", "9"}], ")"}]}]}], ",", "b___"}], 
       "}"}], ":>", 
      RowBox[{"{", 
       RowBox[{"a", ",", 
        RowBox[{"x", "+", 
         RowBox[{"Quotient", "[", 
          RowBox[{"y", ",", "10"}], "]"}]}], ",", 
        RowBox[{"Mod", "[", 
         RowBox[{"y", ",", "10"}], "]"}], ",", "b"}], "}"}]}]}], 
    "]"}]}]}]], "Input",
