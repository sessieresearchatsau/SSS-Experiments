Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "Numeric", " ", "object", " ", "as", " ", "a", " ",
     "wrapper", " ", "for", " ", "a", " ", "list", " ", "of", " ", 
    "integers"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "Numeric", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Custom", " ", "display", " ", "for", " ", "Numeric", " ", "objects"}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Numeric", " ", "/:", " ", 
     RowBox[{"MakeBoxes", "[", 
      RowBox[{
       RowBox[{"Numeric", "[", "list_List", "]"}], ",", "form_"}], "]"}], ":=",
      "\[IndentingNewLine]", "  ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"str", "=", 
         RowBox[{"StringJoin", "[", 
          RowBox[{"ToString", " ", "/@", " ", "list"}], "]"}]}], "}"}], ",", 
       "\[IndentingNewLine]", "    ", 
       RowBox[{"InterpretationBox", "[", 
        RowBox[{"str", ",", 
         RowBox[{"Numeric", "[", "list", "]"}]}], "]"}]}], 
      "\[IndentingNewLine]", "  ", "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Addition", " ", "operation", " ", "for", " ", "Numeric", " ", 
      "objects"}], ",", " ", 
     RowBox[{"extended", " ", "to", " ", "handle", " ", "subtraction"}]}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Numeric", " ", "/:", " ", 
     RowBox[{"Plus", "[", 
      RowBox[{"n1_Numeric", ",", "n2_Numeric"}], "]"}], ":=", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"maxLength", ",", "sum", ",", "result"}], "}"}], ",", 
       "\[IndentingNewLine]", "    ", 
       RowBox[{
        RowBox[{"maxLength", "=", 
         RowBox[{"Max", "[", 
          RowBox[{
           RowBox[{"Length", "[", 
            RowBox[{"n1", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
           RowBox[{"Length", "[", 
            RowBox[{"n2", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"sum", "=", 
         RowBox[{
          RowBox[{"FromDigits", "[", 
           RowBox[{"n1", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "+", 
          RowBox[{"FromDigits", "[", 
           RowBox[{"n2", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"result", "=", 
         RowBox[{"IntegerDigits", "[", 
          RowBox[{
           RowBox[{"Abs", "[", "sum", "]"}], ",", "10", ",", "maxLength"}], 
          "]"}]}], ";", "\[IndentingNewLine]", "    ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"sum", "<", "0"}], ",", 
          RowBox[{"result", "=", 
           RowBox[{"Prepend", "[", 
            RowBox[{"result", ",", "\"\<-\>\""}], "]"}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"Numeric", "[", "result", "]"}]}]}], "\[IndentingNewLine]", 
      "  ", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Multiplication", " ", "operation", " ", "for", " ", "Numeric", " ", 
      "objects"}], ",", " ", 
     RowBox[{"handling", " ", "negatives"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Numeric", " ", "/:", " ", 
     RowBox[{"Times", "[", 
      RowBox[{"k_Integer", ",", "n_Numeric"}], "]"}], ":=", 
     "\[IndentingNewLine]", "  ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"length", ",", "product", ",", "result"}], "}"}], ",", 
       "\[IndentingNewLine]", "    ", 
       RowBox[{
        RowBox[{"length", "=", 
         RowBox[{"Length", "[", 
          RowBox[{"n", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"product", "=", 
         RowBox[{"k", "*", 
          RowBox[{"FromDigits", "[", 
           RowBox[{"n", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"result", "=", 
         RowBox[{"IntegerDigits", "[", 
          RowBox[{
           RowBox[{"Abs", "[", "product", "]"}], ",", "10", ",", "length"}], 
          "]"}]}], ";", "\[IndentingNewLine]", "    ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"product", "<", "0"}], ",", 
          RowBox[{"result", "=", 
           RowBox[{"Prepend", "[", 
            RowBox[{"result", ",", "\"\<-\>\""}], "]"}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", "    ", 
        RowBox[{"Numeric", "[", "result", "]"}]}]}], "\[IndentingNewLine]", 
      "  ", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Example", " ", "usage"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n1", "=", 
     RowBox[{"Numeric", "[", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1", ",", "2", ",", "3"}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n2", "=", 
     RowBox[{"Numeric", "[", 
      RowBox[{"{", 
       RowBox[{"4", ",", "5", ",", "6"}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
