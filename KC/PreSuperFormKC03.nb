   3.9810514885276604`*^9, 3.9810515016821404`*^9}, {3.981051557927326*^9, 
   3.9810515772929993`*^9}, {3.9810516410518456`*^9, 
   3.9810516922143154`*^9}, {3.9810517312847424`*^9, 3.981051937806181*^9}, {
