Cell["Why does this work?", "Text",
 CellChangeTimes->{{3.984858684236288*^9, 
  3.984858802048498*^9}},ExpressionUUID->"2447fcf4-2a49-f040-8871-\
b5d7b23f490f"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"0.11", "\[Times]", "0.11"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"0.1", "\[Times]", "0.1"}], "+", 
     RowBox[{"0.1", "\[Times]", "0.01"}], "+", 
     RowBox[{"0.01", "\[Times]", "0.1"}], "+", 
     RowBox[{"0.01", "\[Times]", "0.01"}]}], "=", 
    RowBox[{
     RowBox[{"0.01", "+", "0.002", "+", "0.0001"}], "=", 
     RowBox[{"0.0121", "."}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"c066620d-6c3c-5147-9732-642c03b159a0"]], \
"Text",
 CellChangeTimes->{{3.984858684236288*^9, 
  3.984858922600033*^9}},ExpressionUUID->"7aac6f75-00d2-f541-8fee-\
1140a651d4d7"],

Cell[TextData[{
 "It\[CloseCurlyQuote]s because while there is only one term ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["10", 
      RowBox[{"-", "1"}]], 
     SuperscriptBox["10", 
      RowBox[{"-", "1"}]]}], "=", 
    SuperscriptBox["10", 
     RowBox[{"-", "2"}]]}], TraditionalForm]],ExpressionUUID->
  "e76d2bb6-2daf-6741-995c-1dbc72661e09"],
 ", there are 2 terms ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "3"}]], TraditionalForm]],ExpressionUUID->
  "4c7be74d-1a92-9c45-aaae-21ed08e7ddc8"],
 ". In longer repetitions the number of terms of a given order grows, and in \
the case of an infinite repetition that growth would continue. For finite \
repetitions, it grows, reaches a maximum, and then decreases back to 0."
}], "Text",
 CellChangeTimes->{{3.984858684236288*^9, 3.9848591575123577`*^9}, 
   3.9849312923456326`*^9},ExpressionUUID->"26505ddf-bbf5-0e45-ac44-\
9c69a7e3b247"],

Cell[CellGroupData[{

Cell["Work out an explanation", "Subsubsection",
 CellChangeTimes->{{3.9850276474356956`*^9, 
  3.985027654774006*^9}},ExpressionUUID->"90127101-c321-6b45-a36b-\
4b1bcf5bd5d8"],

Cell["\<\
This table shows a sort of multiplication table of the different digits, with \
products on diagonals (colored for convenience) adding up to form the \
increasing and then decreasing digits of the answer.\
\>", "Text",
 CellChangeTimes->{{3.984858684236288*^9, 3.9848591575123577`*^9}, {
  3.9849312936343975`*^9, 3.9849313307856617`*^9}, {3.9849346257716255`*^9, 
  3.984934687562727*^9}, {3.984994021271223*^9, 
  3.9849940277923164`*^9}},ExpressionUUID->"efa64c20-60e8-ee45-8965-\
64d0c34527e6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "size", " ", "of", " ", "the", " ", "table"}], 
   " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"n", "=", 
     RowBox[{"1", "+", "9"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Create", " ", "the", " ", "table", " ", "with", " ", "the", " ", 
     "desired", " ", "structure"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"table", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"1", ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"table", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "1"}], "]"}], "]"}], "=", "\"\<\[Times]\>\""}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Function", " ", "to", " ", "generate", " ", "a", " ", "color", " ", 
     "based", " ", "on", " ", "the", " ", "diagonal", " ", "index"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"colorFunction", "[", 
     RowBox[{"{", 
      RowBox[{"i_", ",", "j_"}], "}"}], "]"}], ":=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"i", "==", "1"}], "||", 
       RowBox[{"j", "==", "1"}]}], ",", "White", ",", 
      RowBox[{"Hue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Mod", "[", 
          RowBox[{
           RowBox[{"i", "+", "j"}], ",", "n"}], "]"}], "/", "n"}], ",", "0.3",
         ",", "0.9"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Apply", " ", "the", " ", "color", " ", "function", " ", "to", " ", 
     "each", " ", "element", " ", "based", " ", "on", " ", "its", " ", 
     "position"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"coloredTable", "=", 
     RowBox[{"MapIndexed", "[", "\[IndentingNewLine]", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"Item", "[", 
         RowBox[{"#1", ",", 
          RowBox[{"Background", "->", 
           RowBox[{"colorFunction", "[", "#2", "]"}]}]}], "]"}], " ", "&"}], ",",
        "\[IndentingNewLine]", "  ", "table", ",", 
       RowBox[{"{", "2", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Display", " ", "the", " ", "table", " ", "with", " ", "bold", " ", 
     "dividers", " ", "and", " ", "colored", " ", "diagonals"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Grid", "[", 
    RowBox[{"coloredTable", ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"Dividers", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"2", "->", "Thick"}], "}"}], ",", 
        RowBox[{"{", 
