Cell["\<\
The first I-Cat climbs the hill, the second gives the peak or mesa at the \
top, the third climbs back down.\
\>", "Text",
 CellChangeTimes->{{3.985205525692137*^9, 
  3.985205586348774*^9}},ExpressionUUID->"b67e949b-00ae-2e4c-a19e-\
1b9ba77fc5db"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Defensible explanation", "Subsubsection",
 CellChangeTimes->{{3.9850276474356956`*^9, 
  3.9850276759206066`*^9}},ExpressionUUID->"d29dc82b-a55e-1b44-8842-\
73ae9531a5ae"],

Cell["\<\
New hypothesis/explanation:  Since each digit 1  in the two factors actually \
represents a decreasing power of 10, and all of the powers of 10 in one \
factor have to be multiplied by all of the powers of 10 in the other factor, \
we\[CloseCurlyQuote]re just adding up all of the \[OpenCurlyDoubleQuote]digit \
products\[CloseCurlyDoubleQuote], and those on the same diagonal will clearly \
end up being the same power of 10 and will be added to make that digit of the \
product! When we run out of digits of one factor, but not the other, the \
number of terms on the diagonal holds steady, only beginning to decrease \
after we pass the repeating sections of both factors.\
\>", "Text",
 CellChangeTimes->{{3.98485923141733*^9, 3.9848592749894276`*^9}, {
  3.9849311520288105`*^9, 3.984931155902302*^9}, {3.9849348927637215`*^9, 
  3.984934953231312*^9}, {3.984934997803549*^9, 3.9849350365256786`*^9}, {
  3.984994275756439*^9, 
  3.984994592370735*^9}},ExpressionUUID->"3beb8a41-3b95-2244-8255-\
98b63da96ee0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "number", " ", "of", " ", "rows", " ", "and", " ",
     "columns", " ", "based", " ", "on", " ", "the", " ", "repetition", " ", 
    "lengths"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"n", "=", 
     RowBox[{"1", "+", "8"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"m", "=", 
     RowBox[{"1", "+", "12"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Create", " ", "the", " ", "table", " ", "with", " ", "the", " ", 
      "desired", " ", "structure"}], ",", " ", 
     RowBox[{
     "using", " ", "powers", " ", "of", " ", "10", " ", "for", " ", "the", " ",
       "first", " ", "row", " ", "and", " ", "column"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"table", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"1", ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "m"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"table", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "1"}], "]"}], "]"}], "=", "\"\<\[Times]\>\""}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "2"}], ",", 
      RowBox[{"i", "<=", "n"}], ",", 
      RowBox[{"i", "++"}], ",", 
      RowBox[{
       RowBox[{"table", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "1"}], "]"}], "]"}], "=", 
       RowBox[{"Superscript", "[", 
        RowBox[{"10", ",", 
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"i", "-", "1"}], ")"}]}]}], "]"}]}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"j", "=", "2"}], ",", 
      RowBox[{"j", "<=", "m"}], ",", 
      RowBox[{"j", "++"}], ",", 
      RowBox[{
       RowBox[{"table", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "j"}], "]"}], "]"}], "=", 
       RowBox[{"Superscript", "[", 
        RowBox[{"10", ",", 
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{"j", "-", "1"}], ")"}]}]}], "]"}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Fill", " ", "the", " ", "interior", " ", "with", " ", "the", " ", 
     "product", " ", "of", " ", "powers", " ", "of", " ", "10", " ", "from", " ",
      "the", " ", "first", " ", "row", " ", "and", " ", "column"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"i", "=", "2"}], ",", 
      RowBox[{"i", "<=", "n"}], ",", 
      RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", "  ", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"j", "=", "2"}], ",", 
        RowBox[{"j", "<=", "m"}], ",", 
        RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", "    ", 
        RowBox[{
         RowBox[{
