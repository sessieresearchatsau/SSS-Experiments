Cell[TextData[{
 "Ah! The lengths of the diagonals increase up to the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["8", "th"], TraditionalForm]],ExpressionUUID->
  "3e972cab-7ae3-8443-a929-f23ecc152f52"],
 " column, then stay constant until the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["12", "th"], TraditionalForm]],ExpressionUUID->
  "cc9adf89-f059-b84e-88ba-1d27d3544b3f"],
 " column, and finally start to decrease again."
}], "Text",
 CellChangeTimes->{{3.98485923141733*^9, 3.9848592749894276`*^9}, {
  3.9849311520288105`*^9, 3.984931155902302*^9}, {3.9849348927637215`*^9, 
