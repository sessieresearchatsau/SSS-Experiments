       RowBox[{
        SuperscriptBox["10", 
         RowBox[{
          RowBox[{"-", "3"}], "k"}]], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", "12"}], "}"}]}], "]"}], ")"}]}], ",", 
    "79"}], "]"}]}]], "Input",
