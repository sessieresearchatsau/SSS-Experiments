Cell[TextData[{
 "Count up in columns 000 to 012, then we hold steady 3 more columns (to the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["15", "th"], TraditionalForm]],ExpressionUUID->
  "271fe8b8-baae-2d4f-adb7-9849678c1d71"],
