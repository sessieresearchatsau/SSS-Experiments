00719ff29856"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "the", " ", "size", " ", "of", " ", "the", " ", "table"}], 
   " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"n", "=", 
     RowBox[{"1", "+", "8"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"m", "=", 
     RowBox[{"1", "+", "12"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Create", " ", "the", " ", "table", " ", "with", " ", "the", " ", 
     "desired", " ", "structure"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"table", "=", 
     RowBox[{"ConstantArray", "[", 
      RowBox[{"1", ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "m"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"table", "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "1"}], "]"}], "]"}], "=", "\"\<\[Times]\>\""}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Function", " ", "to", " ", "generate", " ", "a", " ", "color", " ", 
     "based", " ", "on", " ", "the", " ", "diagonal", " ", "index"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"colorFunction", "[", 
     RowBox[{"{", 
      RowBox[{"i_", ",", "j_"}], "}"}], "]"}], ":=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"i", "==", "1"}], "||", 
       RowBox[{"j", "==", "1"}]}], ",", "White", ",", 
      RowBox[{"Hue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Mod", "[", 
          RowBox[{
           RowBox[{"i", "+", "j"}], ",", "n"}], "]"}], "/", "n"}], ",", "0.3",
         ",", "0.9"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Apply", " ", "the", " ", "color", " ", "function", " ", "to", " ", 
     "each", " ", "element", " ", "based", " ", "on", " ", "its", " ", 
     "position"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"coloredTable", "=", 
     RowBox[{"MapIndexed", "[", "\[IndentingNewLine]", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"Item", "[", 
         RowBox[{"#1", ",", 
          RowBox[{"Background", "->", 
           RowBox[{"colorFunction", "[", "#2", "]"}]}]}], "]"}], " ", "&"}], ",",
        "\[IndentingNewLine]", "  ", "table", ",", 
       RowBox[{"{", "2", "}"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
