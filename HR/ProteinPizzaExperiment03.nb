Cell[TextData[{
 "Comparing the different amino acid ordering wheels and how that influences \
the success concatenating the protein ",
 StyleBox["Pizza6 - SYW\nIn parts! ",
  FontWeight->"Bold"],
 "We are removing the GSHM and only adding in the repeats for Block A and \
then Block B"
}], "Text",
