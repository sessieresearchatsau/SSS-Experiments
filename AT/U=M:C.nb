Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Format", "[", 
    RowBox[{"CarryForm", "[", "n_Integer", "]"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "}"}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Superscript", "[", 
           RowBox[{"\"\<\[InvisiblePrefixScriptBase]\>\"", ",", 
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]}], "]"}], "&"}], "[", 
    RowBox[{"QuotientRemainder", "[", 
     RowBox[{"n", ",", "10"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"CarryForm", ",", "Listable"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.977841370632276*^9, 3.977841375165588*^9}, {
  3.977841451969356*^9, 3.9778414537619333`*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"7aa8685b-e16e-4361-9260-28369fd03769"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"MakeBoxes", "[", 
    RowBox[{
     RowBox[{"PreSuperForm", "[", "n_Integer", "]"}], ",", "form_"}], "]"}], ":=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"qr", "=", 
       RowBox[{"QuotientRemainder", "[", 
        RowBox[{"n", ",", "10"}], "]"}]}], "}"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"qr", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
         RowBox[{"ToString", "[", 
          RowBox[{"qr", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}], "}"}], "]"}], ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"SuperscriptBox", "[", 
           RowBox[{"\"\<\[InvisiblePrefixScriptBase]\>\"", ",", 
            RowBox[{"ToString", "[", 
             RowBox[{"qr", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"ToString", "[", 
           RowBox[{"qr", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}], "]"}]}], "]"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"SetAttributes", "[", 
  RowBox[{"PreSuperForm", ",", "Listable"}], "]"}]}], "Input",
 CellChangeTimes->{{3.978636058934688*^9, 3.978636061079179*^9}, 
   3.97863609445601*^9},
 CellLabel->"In[5]:=",ExpressionUUID->"463960c4-6dba-4b4c-a930-b0a58d4de898"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "resolveCarryWithLog", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"resolveCarryWithLog", "[", 
   RowBox[{"l", " ", ":", " ", 
    RowBox[{"{", "__Integer", "}"}]}], "]"}], ":=", "\[IndentingNewLine]", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"carryList", "=", "l"}], ",", 
      RowBox[{"changes", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"pos", "=", 
       RowBox[{"Length", "[", "l", "]"}]}], ",", "x", ",", "y", ",", 
      RowBox[{"states", "=", 
       RowBox[{"{", "l", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"pos", ">", "1"}], ",", "\[IndentingNewLine]", "   ", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}], "=", 
         RowBox[{"carryList", "[", 
          RowBox[{"[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"pos", "-", "1"}], ",", "pos"}], "}"}], "]"}], "]"}]}], ";",
         "\[IndentingNewLine]", "   ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"y", "<", "0"}], "||", 
           RowBox[{"y", ">", "9"}]}], ",", "\[IndentingNewLine]", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{"carryList", "[", 
             RowBox[{"[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"pos", "-", "1"}], ",", "pos"}], "}"}], "]"}], "]"}], 
            "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"x", "+", 
               RowBox[{"Quotient", "[", 
                RowBox[{"y", ",", "10"}], "]"}]}], ",", 
              RowBox[{"Mod", "[", 
               RowBox[{"y", ",", "10"}], "]"}]}], "}"}]}], ";", 
           "\[IndentingNewLine]", "    ", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"states", ",", "carryList"}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "   ", "]"}], ";", "\[IndentingNewLine]", 
        "   ", 
        RowBox[{"pos", "--"}], ";"}]}], "\[IndentingNewLine]", "  ", "]"}], ";",
      "\[IndentingNewLine]", "  ", "states"}]}], "\[IndentingNewLine]", " ", 
   "]"}]}]}], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"bbf31f44-3ed9-4b9d-9784-3cc028d69d2f"],

Cell["\<\
To determine the number of copies to unpack, U, from the multiplicand \
I-Cat(s), divide the number of digits in the multiplier, M, by the number of \
digits in the I-Cat that is being unpack, C. This is written as: U = M/C.
\
\>", "Text",
 CellChangeTimes->{{3.981134377617814*^9, 
  3.98113450723846*^9}},ExpressionUUID->"fb28815f-712d-4487-9ecf-\
126896206c49"],

