          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]}], "]"}], "&"}], "[", 
    RowBox[{"QuotientRemainder", "[", 
     RowBox[{"n", ",", "10"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"CarryForm", ",", "Listable"}], "]"}], ";"}]}], "Input",
