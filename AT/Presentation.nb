Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Format", "[", 
    RowBox[{"CarryForm", "[", "n_Integer", "]"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "}"}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Superscript", "[", 
           RowBox[{"\"\<\[InvisiblePrefixScriptBase]\>\"", ",", 
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]}], "]"}], "&"}], "[", 
    RowBox[{"QuotientRemainder", "[", 
     RowBox[{"n", ",", "10"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"CarryForm", ",", "Listable"}], "]"}], ";"}]}], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"c9d20f90-262c-41f6-9331-81194edd338a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"MakeBoxes", "[", 
    RowBox[{
     RowBox[{"PreSuperForm", "[", "n_Integer", "]"}], ",", "form_"}], "]"}], ":=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"qr", "=", 
       RowBox[{"QuotientRemainder", "[", 
        RowBox[{"n", ",", "10"}], "]"}]}], "}"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"qr", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
         RowBox[{"ToString", "[", 
          RowBox[{"qr", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}], "}"}], "]"}], ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"SuperscriptBox", "[", 
           RowBox[{"\"\<\[InvisiblePrefixScriptBase]\>\"", ",", 
            RowBox[{"ToString", "[", 
             RowBox[{"qr", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"ToString", "[", 
           RowBox[{"qr", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}], "]"}]}], "]"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"SetAttributes", "[", 
  RowBox[{"PreSuperForm", ",", "Listable"}], "]"}]}], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"da114af3-2703-4ebd-9570-aa41a39cb4dd"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "resolveCarryWithLog", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"resolveCarryWithLog", "[", 
   RowBox[{"l", " ", ":", " ", 
    RowBox[{"{", "__Integer", "}"}]}], "]"}], ":=", "\[IndentingNewLine]", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"carryList", "=", "l"}], ",", 
      RowBox[{"changes", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"pos", "=", 
       RowBox[{"Length", "[", "l", "]"}]}], ",", "x", ",", "y", ",", 
      RowBox[{"states", "=", 
       RowBox[{"{", "l", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"pos", ">", "1"}], ",", "\[IndentingNewLine]", "   ", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}], "=", 
         RowBox[{"carryList", "[", 
          RowBox[{"[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"pos", "-", "1"}], ",", "pos"}], "}"}], "]"}], "]"}]}], ";",
         "\[IndentingNewLine]", "   ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"y", "<", "0"}], "||", 
           RowBox[{"y", ">", "9"}]}], ",", "\[IndentingNewLine]", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{"carryList", "[", 
             RowBox[{"[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"pos", "-", "1"}], ",", "pos"}], "}"}], "]"}], "]"}], 
            "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"x", "+", 
               RowBox[{"Quotient", "[", 
                RowBox[{"y", ",", "10"}], "]"}]}], ",", 
              RowBox[{"Mod", "[", 
               RowBox[{"y", ",", "10"}], "]"}]}], "}"}]}], ";", 
           "\[IndentingNewLine]", "    ", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"states", ",", "carryList"}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "   ", "]"}], ";", "\[IndentingNewLine]", 
        "   ", 
        RowBox[{"pos", "--"}], ";"}]}], "\[IndentingNewLine]", "  ", "]"}], ";",
      "\[IndentingNewLine]", "  ", "states"}]}], "\[IndentingNewLine]", " ", 
   "]"}]}]}], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"8efa5d61-7508-4081-849c-4bf0281a730a"],

