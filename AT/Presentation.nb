     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"qr", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
