Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Format", "[", 
    RowBox[{"CarryForm", "[", "n_Integer", "]"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "}"}], "]"}], ",", 
