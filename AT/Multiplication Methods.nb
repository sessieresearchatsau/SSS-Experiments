Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Format", "[", 
    RowBox[{"CarryForm", "[", "n_Integer", "]"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "}"}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Superscript", "[", 
           RowBox[{"\"\<\[InvisiblePrefixScriptBase]\>\"", ",", 
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]}], "]"}], "&"}], "[", 
    RowBox[{"QuotientRemainder", "[", 
     RowBox[{"n", ",", "10"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"CarryForm", ",", "Listable"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.977841370632276*^9, 3.977841375165588*^9}, {
  3.977841451969356*^9, 3.9778414537619333`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"22fd0423-8790-471e-9934-a9bc346dca65"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"MakeBoxes", "[", 
    RowBox[{
     RowBox[{"PreSuperForm", "[", "n_Integer", "]"}], ",", "form_"}], "]"}], ":=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"qr", "=", 
       RowBox[{"QuotientRemainder", "[", 
        RowBox[{"n", ",", "10"}], "]"}]}], "}"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"qr", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
         RowBox[{"ToString", "[", 
          RowBox[{"qr", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}], "}"}], "]"}], ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"SuperscriptBox", "[", 
           RowBox[{"\"\<\[InvisiblePrefixScriptBase]\>\"", ",", 
            RowBox[{"ToString", "[", 
             RowBox[{"qr", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"ToString", "[", 
           RowBox[{"qr", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "]"}]}], "}"}], "]"}]}], "]"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"SetAttributes", "[", 
  RowBox[{"PreSuperForm", ",", "Listable"}], "]"}]}], "Input",
 CellChangeTimes->{{3.978636058934688*^9, 3.978636061079179*^9}, 
   3.97863609445601*^9},
 CellLabel->"In[3]:=",ExpressionUUID->"e107e51e-e4f1-4d62-bea6-5dcf689143ad"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "resolveCarryWithLog", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"resolveCarryWithLog", "[", 
   RowBox[{"l", " ", ":", " ", 
    RowBox[{"{", "__Integer", "}"}]}], "]"}], ":=", "\[IndentingNewLine]", 
  " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"carryList", "=", "l"}], ",", 
      RowBox[{"changes", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"pos", "=", 
       RowBox[{"Length", "[", "l", "]"}]}], ",", "x", ",", "y", ",", 
      RowBox[{"states", "=", 
       RowBox[{"{", "l", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"pos", ">", "1"}], ",", "\[IndentingNewLine]", "   ", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}], "=", 
         RowBox[{"carryList", "[", 
          RowBox[{"[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"pos", "-", "1"}], ",", "pos"}], "}"}], "]"}], "]"}]}], ";",
         "\[IndentingNewLine]", "   ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"y", "<", "0"}], "||", 
           RowBox[{"y", ">", "9"}]}], ",", "\[IndentingNewLine]", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{"carryList", "[", 
             RowBox[{"[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"pos", "-", "1"}], ",", "pos"}], "}"}], "]"}], "]"}], 
            "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"x", "+", 
               RowBox[{"Quotient", "[", 
                RowBox[{"y", ",", "10"}], "]"}]}], ",", 
              RowBox[{"Mod", "[", 
               RowBox[{"y", ",", "10"}], "]"}]}], "}"}]}], ";", 
           "\[IndentingNewLine]", "    ", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"states", ",", "carryList"}], "]"}], ";"}]}], 
         "\[IndentingNewLine]", "   ", "]"}], ";", "\[IndentingNewLine]", 
        "   ", 
        RowBox[{"pos", "--"}], ";"}]}], "\[IndentingNewLine]", "  ", "]"}], ";",
      "\[IndentingNewLine]", "  ", "states"}]}], "\[IndentingNewLine]", " ", 
   "]"}]}]}], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"9eee1887-0eed-4bf1-a0d7-d854ae9b99e2"],

