 RowBox[{
  RowBox[{
   RowBox[{"MakeBoxes", "[", 
    RowBox[{
     RowBox[{"PreSuperForm", "[", "n_Integer", "]"}], ",", "form_"}], "]"}], ":=", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"qr", "=", 
       RowBox[{"QuotientRemainder", "[", 
        RowBox[{"n", ",", "10"}], "]"}]}], "}"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"qr", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
         RowBox[{"ToString", "[", 
          RowBox[{"qr", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}], "}"}], "]"}], ",", 
       RowBox[{"RowBox", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"SuperscriptBox", "[", 
           RowBox[{"\"\<\[InvisiblePrefixScriptBase]\>\"", ",", 
