Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Format", "[", 
    RowBox[{"CarryForm", "[", "n_Integer", "]"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], "==", "0"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{"#", "[", 
          RowBox[{"[", "2", "]"}], "]"}], "}"}], "]"}], ",", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Superscript", "[", 
           RowBox[{"\"\<\[InvisiblePrefixScriptBase]\>\"", ",", 
            RowBox[{"#", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "]"}], ",", 
          RowBox[{"#", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], "}"}], "]"}]}], "]"}], "&"}], "[", 
    RowBox[{"QuotientRemainder", "[", 
     RowBox[{"n", ",", "10"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"CarryForm", ",", "Listable"}], "]"}], ";"}]}], "Input",
